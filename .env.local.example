# Рядок підключення до MongoDB (локально або MongoDB Atlas)
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/veranda

# NextAuth.js
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Публічний URL застосунку — для metadata, sitemap та robots
NEXT_PUBLIC_SITE_URL=http://localhost:3000
